{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Distributed Event Processing Platform — Production Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Throughput",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "displayMode": "list" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "expr": "rate(events_received_total[1m])",
          "legendFormat": "Events/sec received"
        }
      ],
      "title": "Event Ingestion Rate",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "targets": [
        {
          "expr": "rate(events_delivered_total[1m])",
          "legendFormat": "Events/sec delivered"
        }
      ],
      "title": "Webhook Delivery Rate",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "targets": [
        {
          "expr": "rate(events_failed_total[1m])",
          "legendFormat": "Failures/sec"
        },
        {
          "expr": "rate(dlq_events_total[1m])",
          "legendFormat": "DLQ/sec"
        }
      ],
      "title": "Failure Rate",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Latency",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ms" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 4,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(outbox_publish_latency_ms_bucket[1m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(outbox_publish_latency_ms_bucket[1m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(outbox_publish_latency_ms_bucket[1m]))",
          "legendFormat": "p99"
        }
      ],
      "title": "Outbox → Kafka Publish Latency",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ms" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 5,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(webhook_latency_ms_bucket[1m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(webhook_latency_ms_bucket[1m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(webhook_latency_ms_bucket[1m]))",
          "legendFormat": "p99"
        }
      ],
      "title": "Webhook HTTP Call Latency",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "Retries & DLQ",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 },
      "id": 6,
      "targets": [
        {
          "expr": "rate(retry_attempts_total[5m])",
          "legendFormat": "Retry rate"
        }
      ],
      "title": "Retry Attempt Rate",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 19 },
      "id": 7,
      "targets": [
        {
          "expr": "increase(dlq_events_total[1h])",
          "legendFormat": "DLQ events / hour"
        }
      ],
      "title": "DLQ Events per Hour",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 19 },
      "id": 8,
      "targets": [
        {
          "expr": "rate(consumer_duplicates_skipped_total[5m])",
          "legendFormat": "Duplicates skipped/sec"
        }
      ],
      "title": "Consumer Deduplication Rate",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 103,
      "title": "JVM & System",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "bytes" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "id": 9,
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{application=\"producer-service\"}",
          "legendFormat": "producer: {{area}}"
        },
        {
          "expr": "jvm_memory_used_bytes{application=\"consumer-worker\"}",
          "legendFormat": "consumer: {{area}}"
        }
      ],
      "title": "JVM Heap Usage",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "id": 10,
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=\"producer-service\"}",
          "legendFormat": "producer active"
        },
        {
          "expr": "hikaricp_connections_pending{application=\"producer-service\"}",
          "legendFormat": "producer pending"
        }
      ],
      "title": "HikariCP Connection Pool",
      "type": "timeseries"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "tags": ["kafka", "spring-boot", "events"],
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Distributed Event Platform",
  "uid": "event-platform-v1",
  "version": 1
}
